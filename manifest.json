// Supabase Edge Function placeholder for AI receipt parsing.
// Deploy later with: supabase functions deploy parse-receipt
// Set secrets later, for example: supabase secrets set OPENAI_API_KEY=your_key

import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

serve(async (req) => {
  try {
    const { receipt_id } = await req.json();
    if (!receipt_id) return new Response(JSON.stringify({ error: "Missing receipt_id" }), { status: 400 });

    const supabaseUrl = Deno.env.get("SUPABASE_URL")!;
    const serviceRoleKey = Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!;
    const client = createClient(supabaseUrl, serviceRoleKey);

    // This starter function marks the receipt as pending.
    // Add OCR/AI logic here later. Keep API keys on the server, not in app.js.
    await client
      .from("receipts")
      .update({ parse_status: "pending" })
      .eq("id", receipt_id);

    return new Response(JSON.stringify({ ok: true, message: "Parser placeholder reached." }), {
      headers: { "Content-Type": "application/json" },
    });
  } catch (error) {
    return new Response(JSON.stringify({ error: error.message }), { status: 500 });
  }
});
